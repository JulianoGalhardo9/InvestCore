{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "SuperSecretKeyForInvestCoreApplication2026!",
    "Issuer": "InvestCore",
    "Audience": "InvestCoreClients"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "identity-swagger": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/swagger-identity/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/swagger/{**catch-all}" } ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "AuthorizationPolicy": "RequireToken" 
      },
      "order-swagger": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/swagger-order/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/swagger/{**catch-all}" } ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5001" } }
      },
      "order-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5257" } }
      }
    }
  }
}